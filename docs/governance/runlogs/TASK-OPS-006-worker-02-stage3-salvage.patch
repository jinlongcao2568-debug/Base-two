+        "project_id": "project-cn-review-001",
+        "source_family": "ggzy_national",
+        "region_code": "CN-320100",
+        "ingestion_job_id": "job-ignored",
+        "captured_at": "2026-04-05T10:00:00+08:00",
+        "raw_payload": {
+            "scenario_id": "case_review_ready",
+            "project_id": "project-cn-review-001",
+            "source_family": "ggzy_national",
+            "region_code": "CN-320100",
+            "project_name": "raw-name-should-not-leak",
+        },
+    }
+
+    project_base = build_project_base(artifact)
+
+    assert project_base["project_id"] == "project-cn-review-001"
