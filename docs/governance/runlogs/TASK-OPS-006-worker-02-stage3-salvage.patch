+
+def test_stage3_project_base_rejects_identity_mismatch_between_artifact_and_raw_payload() -> None:
+    artifact = {
+        "project_id": "project-cn-review-001",
+        "source_family": "ggzy_national",
+        "raw_payload": {
+            "scenario_id": "case_review_ready",
+            "project_id": "project-cn-review-001",
+            "source_family": "other-source-family",
+            "region_code": "CN-320100",
+        },
+    }
+
+    with pytest.raises(ValueError, match="source_family mismatch between artifact and raw_payload"):
+        build_project_base(artifact)
