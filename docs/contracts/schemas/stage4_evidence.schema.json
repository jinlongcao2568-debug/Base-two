{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ax9.local/contracts/stage4_evidence.schema.json",
  "title": "AX9 Stage 4 Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidence_id",
    "project_id",
    "source_url",
    "source_type",
    "capture_type",
    "capture_time",
    "page_title",
    "snippet",
    "evidence_artifact_refs",
    "structured_field_refs",
    "consumed_by_rule_codes",
    "evidence_grade",
    "evidence_hash"
  ],
  "properties": {
    "evidence_id": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "source_url": {
      "type": "string",
      "minLength": 1
    },
    "source_type": {
      "type": "string",
      "minLength": 1
    },
    "capture_type": {
      "type": "string",
      "minLength": 1
    },
    "capture_time": {
      "type": "string",
      "format": "date-time"
    },
    "page_title": {
      "type": "string",
      "minLength": 1
    },
    "snippet": {
      "type": "string",
      "minLength": 1
    },
    "evidence_artifact_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "structured_field_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "consumed_by_rule_codes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_grade": {
      "type": "string",
      "enum": ["A", "B", "C"]
    },
    "evidence_hash": {
      "type": "string",
      "minLength": 1
    }
  }
}
