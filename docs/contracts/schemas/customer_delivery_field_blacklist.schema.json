{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ax9s.local/contracts/customer_delivery_field_blacklist.schema.json",
  "title": "customer_delivery_field_blacklist",
  "type": "object",
  "required": [
    "version",
    "updated_at",
    "approval_and_masking_dictionary",
    "release_blockers"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "approval_and_masking_dictionary": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "classification",
          "approval_required",
          "masking_rule",
          "external_audit_required"
        ],
        "properties": {
          "classification": {
            "type": "string"
          },
          "approval_required": {
            "type": "boolean"
          },
          "approval_role": {
            "type": [
              "string",
              "null"
            ]
          },
          "masking_rule": {
            "type": "string"
          },
          "external_audit_required": {
            "type": "boolean"
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "approval_required": {
                  "const": true
                }
              }
            },
            "then": {
              "required": [
                "approval_role"
              ],
              "properties": {
                "approval_role": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        ],
        "additionalProperties": true
      }
    },
    "release_blockers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    }
  },
  "additionalProperties": true
}