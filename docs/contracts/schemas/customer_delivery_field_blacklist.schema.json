{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ax9s.local/contracts/customer_delivery_field_blacklist.schema.json",
  "title": "customer_delivery_field_blacklist",
  "type": "object",
  "required": [
    "version",
    "template_name",
    "updated_at",
    "field_policy_dictionary_source",
    "delivery_object_matrix_source",
    "blacklist",
    "release_blockers"
  ],
  "properties": {
    "version": { "type": "string" },
    "template_name": { "const": "customer_delivery_field_blacklist" },
    "updated_at": { "type": "string" },
    "description": { "type": "string" },
    "rules": { "type": "object" },
    "field_policy_dictionary_source": { "type": "string", "minLength": 1 },
    "delivery_object_matrix_source": { "type": "string", "minLength": 1 },
    "blacklist": { "type": "object", "minProperties": 1 },
    "notes": { "type": "array", "items": { "type": "string" } },
    "release_blockers": { "type": "array", "minItems": 1, "items": { "type": "string" } }
  },
  "additionalProperties": true
}
