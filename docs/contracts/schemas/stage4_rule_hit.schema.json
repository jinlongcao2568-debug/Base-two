{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ax9.local/contracts/stage4_rule_hit.schema.json",
  "title": "AX9 Stage 4 Rule Hit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "rule_hit_id",
    "project_id",
    "rule_code",
    "severity",
    "confidence",
    "result_type",
    "why_hit",
    "boundary_note",
    "evidence_refs",
    "target_entity_type",
    "target_entity_id",
    "review_status"
  ],
  "properties": {
    "rule_hit_id": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "rule_code": {
      "type": "string",
      "minLength": 1
    },
    "severity": {
      "type": "string",
      "enum": ["HIGH", "MEDIUM", "LOW"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "result_type": {
      "type": "string",
      "enum": ["AUTO_HIT", "CLUE", "OBSERVATION"]
    },
    "why_hit": {
      "type": "string",
      "minLength": 1
    },
    "boundary_note": {
      "type": "string",
      "minLength": 1
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "target_entity_type": {
      "type": "string",
      "minLength": 1
    },
    "target_entity_id": {
      "type": "string",
      "minLength": 1
    },
    "review_status": {
      "type": "string",
      "enum": ["PENDING", "CONFIRMED", "REJECTED", "OVERRIDDEN"]
    }
  }
}
