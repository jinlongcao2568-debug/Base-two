{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ax9.local/contracts/stage5_report_record.schema.json",
  "title": "AX9 Stage 5 Report Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_id",
    "project_id",
    "brief_path",
    "evidence_pack_path",
    "objection_draft_path",
    "review_request_list_path",
    "review_task_status",
    "report_status",
    "written_back_at"
  ],
  "properties": {
    "report_id": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "brief_path": {
      "type": "string",
      "minLength": 1
    },
    "evidence_pack_path": {
      "type": "string",
      "minLength": 1
    },
    "objection_draft_path": {
      "type": "string",
      "minLength": 1
    },
    "review_request_list_path": {
      "type": "string",
      "minLength": 1
    },
    "review_task_status": {
      "type": "string",
      "minLength": 1
    },
    "report_status": {
      "type": "string",
      "enum": ["DRAFT", "READY", "ISSUED", "REVOKED"]
    },
    "written_back_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
