{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ax9s.local/contracts/customer_delivery_field_whitelist.schema.json",
  "title": "customer_delivery_field_whitelist",
  "type": "object",
  "required": [
    "version",
    "updated_at",
    "delivery_object_matrix"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "delivery_object_matrix": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": {
        "^[a-zA-Z0-9_]+$": {
          "type": "object",
          "minProperties": 1,
          "patternProperties": {
            "^[a-zA-Z0-9_]+$": {
              "type": "object",
              "required": [
                "allowed_groups",
                "conditional_groups",
                "blocked_groups",
                "approval_required",
                "audit_required"
              ],
              "properties": {
                "allowed_groups": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "conditional_groups": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "blocked_groups": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "approval_required": {
                  "type": "boolean"
                },
                "audit_required": {
                  "type": "boolean"
                }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "conditional_field_policy_refs": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}