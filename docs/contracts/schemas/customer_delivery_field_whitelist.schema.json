{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ax9s.local/contracts/customer_delivery_field_whitelist.schema.json",
  "title": "customer_delivery_field_whitelist",
  "type": "object",
  "required": [
    "version",
    "template_name",
    "updated_at",
    "field_policy_dictionary_source",
    "delivery_object_matrix_source",
    "allowlist",
    "conditional_allowlist"
  ],
  "properties": {
    "version": { "type": "string" },
    "template_name": { "const": "customer_delivery_field_whitelist" },
    "updated_at": { "type": "string" },
    "description": { "type": "string" },
    "rules": { "type": "object" },
    "field_policy_dictionary_source": { "type": "string", "minLength": 1 },
    "delivery_object_matrix_source": { "type": "string", "minLength": 1 },
    "coverage_governance_registry_source": { "type": "string", "minLength": 1 },
    "allowlist": { "type": "object", "minProperties": 1 },
    "conditional_allowlist": { "type": "array", "items": { "type": "object" } },
    "conditional_field_policy_refs": { "type": "object", "additionalProperties": { "type": "string" } }
  },
  "additionalProperties": true
}
